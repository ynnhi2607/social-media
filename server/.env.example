# Server Environment Variables
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_media

# JWT Secret (generate with: openssl rand -hex 64 or node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-super-long-random-secret-key-change-this-in-production

# Cloudinary Configuration (for image uploads)
# Sign up for free at: https://cloudinary.com/users/register_free
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
